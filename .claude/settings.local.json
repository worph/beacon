{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(uv sync:*)",
      "Bash(pip3 --version)",
      "Bash(curl -LsSf https://astral.sh/uv/install.sh)",
      "Bash(sh)",
      "Bash(export PATH=\"$HOME/.local/bin:$PATH\")",
      "Bash(uv run:*)",
      "Bash(docker compose:*)",
      "Bash(curl -s http://localhost:3000/api/status)",
      "Bash(python3 -m json.tool)",
      "Bash(curl -s http://localhost:3000/api/servers)",
      "Bash(uv run python -c \":*)",
      "Bash(curl -s -o /dev/null -w \"Web UI: HTTP %{http_code}\\\\n\" http://localhost:3000/)",
      "Bash(git init:*)",
      "Bash(git remote:*)"
    ]
  }
}
